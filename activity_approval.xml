<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A0E1A"
    android:padding="24dp">

    <!-- Header -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="⚡ AÇÃO REQUERIDA"
        android:textSize="12sp"
        android:textColor="#E040FB"
        android:letterSpacing="0.2"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tv_approval_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tv_approval_severity"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="12sp"
        android:textColor="#FF1744"
        android:layout_marginBottom="20dp"/>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1E3A5F"
        android:layout_marginBottom="20dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="DESCRIÇÃO"
        android:textSize="10sp"
        android:textColor="#5A8AB0"
        android:letterSpacing="0.2"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tv_approval_description"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="14sp"
        android:textColor="#E0E6F0"
        android:lineSpacingExtra="4dp"
        android:layout_marginBottom="24dp"/>

    <!-- Warning Box -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1A140A"
        android:padding="16dp"
        android:layout_marginBottom="32dp">

        <TextView
            android:id="@+id/tv_approval_warning"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="13sp"
            android:textColor="#FFD600"
            android:lineSpacingExtra="4dp"/>
    </LinearLayout>

    <!-- Spacer -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <!-- Action Buttons -->
    <Button
        android:id="@+id/btn_approve"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="✅  AUTORIZAR AÇÃO"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:backgroundTint="#00E676"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btn_deny"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="❌  NEGAR — MANTER INATIVO"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="#FF4444"
        android:backgroundTint="#1A0A0A"/>

</LinearLayout>
