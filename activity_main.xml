<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0E1A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🛡️"
                android:textSize="36sp"
                android:layout_marginEnd="12dp"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ZERO SEC"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:letterSpacing="0.1"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ANDROID SECURITY AGENT"
                    android:textSize="10sp"
                    android:textColor="#5A8AB0"
                    android:letterSpacing="0.2"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Shizuku Status Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="#0D1B2A"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MODO PRIVILEGIADO"
                    android:textSize="10sp"
                    android:textColor="#5A8AB0"
                    android:letterSpacing="0.2"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:id="@+id/tv_shizuku_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Verificando Shizuku..."
                    android:textSize="14sp"
                    android:textColor="#FFFFFF"
                    android:layout_marginBottom="8dp"/>

                <Button
                    android:id="@+id/btn_request_shizuku"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Conceder Permissão Shizuku"
                    android:textSize="12sp"
                    android:backgroundTint="#1E3A5F"
                    android:textColor="#00E5FF"
                    android:visibility="gone"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Status Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="#0D1B2A"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="STATUS"
                    android:textSize="10sp"
                    android:textColor="#5A8AB0"
                    android:letterSpacing="0.2"
                    android:layout_marginBottom="6dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <View
                        android:id="@+id/scanning_indicator"
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/circle_pulse"
                        android:layout_marginEnd="8dp"
                        android:visibility="gone"/>

                    <TextView
                        android:id="@+id/tv_status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Pronto para varrer"
                        android:textSize="16sp"
                        android:textColor="#00E5FF"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Scan Button -->
        <Button
            android:id="@+id/btn_scan"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="🚀  INICIAR VARREDURA COMPLETA"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:backgroundTint="#00E5FF"
            android:layout_marginBottom="16dp"/>

        <!-- Summary Card (hidden until scan completes) -->
        <LinearLayout
            android:id="@+id/layout_summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#0D1B2A"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                xmlns:app="http://schemas.android.com/apk/res-auto">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ÚLTIMO RELATÓRIO"
                        android:textSize="10sp"
                        android:textColor="#5A8AB0"
                        android:letterSpacing="0.2"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:id="@+id/tv_summary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textSize="14sp"
                        android:textColor="#E0E6F0"
                        android:lineSpacingExtra="4dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- Info Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#060D18"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="COBERTURA DA VARREDURA"
                    android:textSize="10sp"
                    android:textColor="#5A8AB0"
                    android:letterSpacing="0.2"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="⚙️  Processos root e zumbis\n🌐  Portas abertas e conexões suspeitas\n🔓  Malware por hash SHA256\n📁  APKs sideloaded\n🔑  Permissões de spyware\n📋  Logs de autenticação\n🛡️  Verified Boot e criptografia\n📡  Anomalia de tráfego (tempo real)"
                    android:textSize="13sp"
                    android:textColor="#7A9AB8"
                    android:lineSpacingExtra="6dp"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#1E3A5F"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🔒  Ações críticas requerem sua aprovação explícita\n🚫  Nenhum dado pessoal é exportado"
                    android:textSize="12sp"
                    android:textColor="#5A8AB0"
                    android:lineSpacingExtra="4dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
