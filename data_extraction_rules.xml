<?xml version="1.0" encoding="utf-8"?>
<!-- Nenhum dado do app é incluído em backups do sistema -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" path="."/>
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" path="."/>
    </device-transfer>
</data-extraction-rules>
